{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2024"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"types": ["@cloudflare/workers-types", "vitest/globals"],
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules", "dist"]
}
