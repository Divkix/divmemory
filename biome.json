{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noGlobalAssign": "error",
				"noPrototypeBuiltins": "error"
			},
			"style": {
				"useImportType": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"files": {
		"includes": [
			"**",
			"!!**/.wrangler",
			"!!**/node_modules",
			"!!**/dist",
			"!!**/build",
			"!!**/drizzle"
		],
		"ignoreUnknown": true
	}
}
