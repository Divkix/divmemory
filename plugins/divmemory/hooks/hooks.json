{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|clear|compact",
				"hooks": [
					{
						"type": "command",
						"command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-fast.sh\"",
						"async": false
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end.mjs\"",
						"async": false
					}
				]
			}
		]
	}
}
