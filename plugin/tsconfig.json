{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2024"],
		"types": ["vitest/globals", "node"],
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "tests/**/*", "scripts/**/*.d.ts", "scripts/**/*.d.mts"],
	"exclude": ["node_modules", "dist"]
}
